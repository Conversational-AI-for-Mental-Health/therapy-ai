
# Copy this file to .env 
NODE_ENV=development
PORT=3000

JWT_SECRET=randomly_generated_32+_character_string_here

CORS_ORIGIN=http://localhost:8080

MONGODB_URI=mongodb://localhost:27017/therapy-ai

AI_SERVICE_URL=http://localhost:5000

PYTHON_AI_TIMEOUT_MS=120000

# Twilio (optional — SMS emergency alerts)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15005550006

# Emergency professional contact (receives SMS alerts)
PROFESSIONAL_CONTACT_1=+15005550007

# Token expiration settings
ACCESS_TOKEN_EXPIRES_IN=60m
REFRESH_TOKEN_EXPIRES_DAYS=30

# OAuth Client IDs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=your-apple-service-or-bundle-id