{
    "compilerOptions": {
        "target": "es2020",
        "lib": [
            "es2020",
            "dom"
        ],
        "types": [
            "cypress",
            "node"
        ],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "cypress/**/*.ts",
        "cypress.config.ts"
    ]
}